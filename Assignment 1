from itertools import combinations

def tsp(graph):
    n = len(graph)
    dp = {}
    
    for i in range(1, n):
        dp[(1 << i, i)] = (graph[0][i], 0)
    
    for r in range(2, n):
        for subset in combinations(range(1, n), r):
            bits = sum(1 << i for i in subset)
            
            for j in subset:
                prev = bits & ~(1 << j)
                res = []
                
                for k in subset:
                    if k != j:
                        res.append((dp[(prev, k)][0] + graph[k][j], k))
                
                dp[(bits, j)] = min(res)
    
    bits = (1 << n) - 2
    res = []
    
    for j in range(1, n):
        res.append((dp[(bits, j)][0] + graph[j][0], j))
    
    return min(res)
